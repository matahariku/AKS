Étape 3 : Remplir les fichiers un par un

1. Chart.yaml

apiVersion: v2
name: broapp
description: Helm Chart personnalisé - Hello Bro App
type: application
version: 0.1.0
appVersion: « 1.0.0 »
maintainers:
  - name: YourName
    email: you@email.com

2. values.yaml

replicaCount: 2

image:
  repository: nginx
  tag: « 1.27-alpine »
  pullPolicy: IfNotPresent

nameOverride: « »
fullnameOverride: « »

service:
  type: ClusterIP
  port: 80

ingress:
  enabled: true
  className: nginx
  host: broapp.local

resources:
  requests:
    cpu: 100m
    memory: 128Mi
  limits:
    cpu: 300m
    memory: 256Mi

livenessProbe:
  httpGet:
    path: /
    port: http

readinessProbe:
  httpGet:
    path: /
