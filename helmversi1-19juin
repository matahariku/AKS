Update Chart =

1. Update values.yaml (changer tous ses valeurs)

replicaCount: 2

image:
  repository: nginx
  tag: "1.27-alpine"
  pullPolicy: IfNotPresent

nameOverride: ""
fullnameOverride: ""

# Resource presets
resources:
  small:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 300m
      memory: 256Mi
  medium:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: 500m
      memory: 1024Mi

# Pilih preset
resourcePreset: small

service:
  type: ClusterIP
  port: 80

ingress:
  enabled: true
  className: nginx
  host: broapp.local
  tls: false

hpa:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 70

securityContext:
  runAsUser: 101
  runAsNonRoot: true
  allowPrivilegeEscalation: false
  readOnlyRootFilesystem: true

config:
  message: "Hello Bro! Ini versi Advanced Helm Chart"
  environment: production
  featureX: true

